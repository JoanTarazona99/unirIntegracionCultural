# ============================================================================
# KubGU Assistant - Configuration File (.env)
# 
# This file contains ALL configuration parameters. Copy to .env and fill in
# real values. NEVER commit .env to git (it's in .gitignore).
#
# Documentation: See docs/CONFIG.md for detailed explanations
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Application name (for headers, documentation)
APP_NAME=KubGU Assistant

# Application version (semantic versioning)
APP_VERSION=1.0.0

# Debug mode (development only)
DEBUG=true

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://kubgu_user:CHANGE_ME@localhost:5432/kubgu_assistant

# --- Docker Compose credentials (used by docker-compose.yml) ---
# These are required when running `docker compose up`. Never use defaults in prod.
POSTGRES_USER=kubgu_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=kubgu_assistant

# Echo SQL queries (development only)
DATABASE_ECHO=false

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# API SETTINGS
# ============================================================================

# Server host (0.0.0.0 = listen on all interfaces)
API_HOST=0.0.0.0

# Server port
API_PORT=8000

# Number of worker processes (production)
API_WORKERS=4

# Request timeout (seconds)
API_REQUEST_TIMEOUT=30

# ============================================================================
# RAG (RETRIEVAL-AUGMENTED GENERATION)
# ============================================================================

# Number of top documents to retrieve
RAG_TOP_K=10

# Minimum relevance score threshold (0.0-1.0)
# Documents below this score are filtered out
RAG_MIN_SCORE=0.3

# Enable semantic search using sentence-transformers
# WARNING: Requires significant CPU; disabled by default
SEMANTIC_SEARCH_ENABLED=false

# Semantic search model name (from huggingface)
SEMANTIC_SEARCH_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ---- Retrieval strategy (KubGU-RAG) ----
# retrieval_mode: keyword | bm25 | dense | hybrid | hybrid_rerank
#   keyword       = legacy baseline (default, always available)
#   bm25          = lexical BM25 (pure Python, CPU-friendly)
#   dense         = multilingual sentence embeddings (needs sentence-transformers)
#   hybrid        = BM25 + dense fused with Reciprocal Rank Fusion (recommended)
#   hybrid_rerank = hybrid + cross-encoder reranking (highest precision, CPU-heavy)
RETRIEVAL_MODE=keyword
DENSE_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
ENABLE_RERANKER=false
RRF_K=60
RETRIEVAL_TOP_K=5

# ---- Trustworthy AI (grounding / abstention) ----
# When enabled, answers must be grounded in retrieved official sources or the
# assistant abstains and redirects the user to the official source.
ENABLE_CITATION_GUARD=false
ABSTENTION_THRESHOLD=0.35

# LLM provider (ollama, openai, or local)
LLM_PROVIDER=ollama

# LLM model name
LLM_MODEL=llama3

# LLM endpoint (if applicable)
LLM_ENDPOINT=http://localhost:11434

# Ollama server host (read by backend settings as `ollama_host`)
OLLAMA_HOST=http://localhost:11434

# Enable LLM integration (Ollama). Disabled by default.
ENABLE_LLM=false

# ============================================================================
# TRANSLATION
# ============================================================================

# Translation provider (google_trans or static_dict)
TRANSLATION_PROVIDER=google_trans

# Translation timeout (seconds)
TRANSLATION_TIMEOUT=10.0

# Fallback language if translation fails
TRANSLATION_FALLBACK_LANGUAGE=en

# ============================================================================
# TEXT-TO-SPEECH (TTS)
# ============================================================================

# TTS provider (gtts, edge-tts, or web_speech_fallback)
TTS_PROVIDER=gtts

# Enable TTS caching
TTS_CACHE_ENABLED=true

# TTS cache directory
TTS_CACHE_DIR=data/audio

# Default TTS language
TTS_DEFAULT_LANGUAGE=ru

# ============================================================================
# SECURITY
# ============================================================================

# CORS allowed origins (comma-separated)
# SECURITY WARNING: Never use "*" in production!
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# Rate limiting: max requests per window
RATE_LIMIT_REQUESTS=30

# Rate limiting: window size (seconds)
RATE_LIMIT_WINDOW=60

# JWT secret key (for future authentication)
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# JWT algorithm
JWT_ALGORITHM=HS256

# API key for internal services (optional)
API_KEY=your-api-key-here

# ============================================================================
# CACHING
# ============================================================================

# Cache backend (memory, redis, or memcached)
CACHE_BACKEND=memory

# Redis URL (if using Redis)
REDIS_URL=redis://localhost:6379/0

# Cache default TTL (seconds)
CACHE_DEFAULT_TTL=3600

# Cache max entries (for in-memory cache)
CACHE_MAX_ENTRIES=500

# ============================================================================
# LOGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json or text)
# Use 'json' for production (parseable by ELK, Datadog, etc)
LOG_FORMAT=json

# Log file path (leave empty for stdout only)
LOG_FILE_PATH=logs/app.log

# Log rotation (daily, weekly, or size-based)
LOG_ROTATION=daily

# Maximum log file size (MB) for rotation
LOG_MAX_SIZE_MB=100

# Number of backup log files to keep
LOG_BACKUP_COUNT=10

# ============================================================================
# EVALUATION & METRICS
# ============================================================================

# Enable evaluation/metrics collection
METRICS_ENABLED=true

# Ground truth file for RAG evaluation
GROUND_TRUTH_FILE=data/ground_truth_queries.json

# Evaluation report output directory
EVALUATION_OUTPUT_DIR=benchmark_results

# ============================================================================
# TELEGRAM BOT (Optional)
# ============================================================================

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Telegram Bot enabled
TELEGRAM_BOT_ENABLED=false

# Telegram API timeout (seconds)
TELEGRAM_TIMEOUT=30

# ============================================================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================================================

# Email provider (smtp or sendgrid)
EMAIL_PROVIDER=smtp

# SMTP server
SMTP_SERVER=smtp.gmail.com

# SMTP port
SMTP_PORT=587

# SMTP username
SMTP_USER=your-email@gmail.com

# SMTP password
SMTP_PASSWORD=your-app-password

# SMTP TLS
SMTP_TLS=true

# Default from address
EMAIL_FROM=noreply@kubgu-assistant.local

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Google Translate API key (optional, if using Google Cloud)
GOOGLE_TRANSLATE_API_KEY=

# Datadog API key (optional, for monitoring)
DATADOG_API_KEY=

# Sentry DSN (optional, for error tracking)
SENTRY_DSN=

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Container name (for Docker)
CONTAINER_NAME=kubgu-backend

# Container port mapping
CONTAINER_PORT=8000

# Container environment (dev, test, prod)
CONTAINER_ENV=development

# ============================================================================
# EXPERIMENTAL FEATURES
# ============================================================================

# Enable conversation memory persistence
PERSIST_CONVERSATIONS=false

# Maximum conversation history per user
MAX_CONVERSATION_HISTORY=50

# Enable user personalization
ENABLE_PERSONALIZATION=true

# Enable A/B testing
ENABLE_AB_TESTING=false

# ============================================================================
# NOTES FOR DEVELOPERS
# ============================================================================

# 1. SECURITY:
#    - Change JWT_SECRET_KEY in production
#    - Never commit .env to git
#    - Use secrets manager in production (AWS Secrets Manager, HashiCorp Vault, etc)

# 2. PERFORMANCE:
#    - Set LOG_FORMAT=json in production
#    - Enable CACHE_BACKEND=redis for scaling
#    - Adjust RAG_TOP_K based on latency requirements

# 3. DEBUGGING:
#    - Set LOG_LEVEL=DEBUG to see detailed logs
#    - Set DEBUG=true to enable FastAPI debug mode
#    - Use LOG_FORMAT=text for human-readable logs

# 4. TESTING:
#    - Create .env.test for test environment
#    - Use in-memory cache (CACHE_BACKEND=memory) for tests
#    - Use SQLite for tests if possible

# 5. PRODUCTION:
#    - Set ENVIRONMENT=production
#    - Disable DEBUG
#    - Set LOG_LEVEL=WARNING or ERROR
#    - Enable metrics and monitoring
#    - Use strong JWT_SECRET_KEY and API_KEY

# ============================================================================
# EXAMPLE CONFIGURATIONS
# ============================================================================

# DEVELOPMENT:
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=DEBUG
# LOG_FORMAT=text
# CACHE_BACKEND=memory

# TESTING:
# ENVIRONMENT=test
# DEBUG=true
# DATABASE_URL=sqlite:///test.db
# LOG_LEVEL=WARNING
# CACHE_BACKEND=memory

# PRODUCTION:
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# LOG_FORMAT=json
# CACHE_BACKEND=redis
# CORS_ALLOWED_ORIGINS=https://kubgu.ru
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60

# ============================================================================
